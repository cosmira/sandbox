{
    "name": "cosmira/sandbox",
    "description": "Laravel package for dual-table sandbox editing (active / sandbox tables)",
    "keywords": [
        "laravel",
        "sandbox",
        "configuration",
        "edit"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Alexandr Chernyaev",
            "email": "bliz48rus@gmail.com",
            "homepage": "https://tabuna.github.io",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/database": "^12.0 || ^13.0",
        "illuminate/http": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0"
    },
    "require-dev": {
        "dragon-code/benchmark": "^4.5",
        "infection/infection": "^0.32.4",
        "laravel/pint": "^1.27",
        "orchestra/testbench": "^10.0 || ^11.0",
        "phpunit/phpunit": "^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Cosmira\\Sandbox\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cosmira\\Sandbox\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Cosmira\\Sandbox\\SandboxServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "infection/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": [
            "@clear",
            "@php vendor/bin/phpunit"
        ],
        "test:coverage": [
            "@clear",
            "@php -d pcov.enabled=1 -d xdebug.mode=coverage vendor/bin/phpunit --coverage-text"
        ],
        "test:mutation": [
            "@clear",
            "@php vendor/bin/infection"
        ]
    }
}
